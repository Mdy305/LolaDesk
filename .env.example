# ── Copy to .env.local for dev, or set in Vercel → Settings → Environment Variables ──
# NEVER commit real keys. Rotate any key that has ever been pasted into
# a chat, ticket, or doc. Set all "Production, Preview, Development".

# ─────────────────────────────────────────────────────────────────
# CORE — required for the app to function at all
# ─────────────────────────────────────────────────────────────────

# Your deployed URL, no trailing slash. Used to build redirect/webhook
# URLs (OAuth callbacks, Stripe Checkout, Telnyx <Play> audio fetches).
APP_URL=https://www.loladesk.com

# ── Lola's brain (LLM) ──
# LLM_PROVIDER selects which backend api/lib/llm.js calls: "telnyx" (default,
# routes through Telnyx Inference / Kimi-K2.6) or "anthropic" (Claude direct).
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your-new-key
# Optional overrides — only needed if you want a non-default model:
# LLM_MODEL=claude-sonnet-4-6
# LLM_POWER_MODEL=moonshotai/Kimi-K2.6

# ── Telnyx — voice, SMS, and number provisioning ──
TELNYX_API_KEY=KEY-your-new-key
TELNYX_VOICE_APP_ID=your-texml-app-id
TELNYX_MESSAGING_PROFILE=your-messaging-profile-id
# Optional but recommended for webhook signature verification (PEM public key).
TELNYX_PUBLIC_KEY=

# ── Supabase — multi-tenant database + auth ──
# Without these, the app runs in single-tenant "demo mode" (see db.js)
# — it won't crash, but every salon shares the same fake MMΛ Salon data.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ-your-service-role-key-NEVER-the-anon-key

# ── ElevenLabs — Lola's real voice on phone calls AND in the dashboard ──
# Required for Lola to sound like "Lola" (her custom brand voice) rather
# than the generic fallback voice. See api/lib/elevenlabs.js.
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=your-cloned-lola-voice-id
# Optional: ELEVENLABS_MODEL=eleven_turbo_v2_5 (default — optimized for low latency)

# ─────────────────────────────────────────────────────────────────
# SECURITY — required once ANY booking-platform OAuth is connected
# ─────────────────────────────────────────────────────────────────

# AES-256-GCM key that encrypts Square/Boulevard/Shopify OAuth tokens
# at rest. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Losing this key means losing access to every connected integration
# (salons would need to reconnect). Back it up somewhere safe — NOT in git.
INTEGRATION_ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────────────
# BILLING — Stripe subscriptions
# ─────────────────────────────────────────────────────────────────

STRIPE_SECRET_KEY=sk_live_or_sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_from-your-stripe-webhook-endpoint
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_MEDSPA=price_...

# ─────────────────────────────────────────────────────────────────
# BOOKING PLATFORM OAUTH — only set the ones you're actively offering
# ─────────────────────────────────────────────────────────────────

# Square (api/lib/connectors/square.js)
SQUARE_APP_ID=
SQUARE_APP_SECRET=
SQUARE_ENV=sandbox

# Boulevard (api/lib/connectors/boulevard.js)
BOULEVARD_CLIENT_ID=
BOULEVARD_CLIENT_SECRET=
BOULEVARD_ENV=staging

# Vagaro (api/lib/connectors/vagaro.js) — partner program: developer.vagaro.com.
# Connector reports "Coming soon" in Settings until CLIENT_ID is set.
VAGARO_CLIENT_ID=
VAGARO_CLIENT_SECRET=
# VAGARO_AUTH_BASE=   # optional override for sandbox
# VAGARO_API_BASE=    # optional override for sandbox

# Mindbody (api/lib/connectors/mindbody.js) — developers.mindbodyonline.com.
# Needs BOTH an Api-Key (Public API v6) and OAuth client (Mindbody Identity).
# SiteId is captured per-tenant at connect time; MINDBODY_SITE_ID is the
# fallback default (-99 is Mindbody's shared sandbox site).
MINDBODY_API_KEY=
MINDBODY_CLIENT_ID=
MINDBODY_CLIENT_SECRET=
MINDBODY_SITE_ID=

# Fresha (api/lib/connectors/fresha.js) — partner API is invite-only
# (partners@fresha.com). Reports "Coming soon" until CLIENT_ID is set.
FRESHA_CLIENT_ID=
FRESHA_CLIENT_SECRET=
# FRESHA_AUTH_BASE=   # optional override
# FRESHA_API_BASE=    # optional override

# Shopify (api/lib/connectors/shopify.js) — only relevant if salons sell retail products
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Google Calendar (api/lib/connectors/google-calendar.js)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────
# NUMBER RESALE PRICING — recurring revenue knob (api/telnyx-numbers.js)
# Telnyx wholesale is ~$1/mo local, ~$2/mo toll-free. You keep the spread.
# ─────────────────────────────────────────────────────────────────
NUMBER_RETAIL_MONTHLY=5
NUMBER_RETAIL_TOLLFREE_MONTHLY=9
