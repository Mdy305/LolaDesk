{
  "cleanUrls": true,
  "buildCommand": "echo 'No build step needed (static HTML + serverless)'",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/start",     "destination": "/onboarding.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/login",     "destination": "/login.html" },
    { "source": "/admin",     "destination": "/admin.html" },
    { "source": "/clients",   "destination": "/clients.html" },
    { "source": "/calls",     "destination": "/calls.html" },
    { "source": "/inbox",     "destination": "/inbox.html" },
    { "source": "/bookings",  "destination": "/bookings.html" },
    { "source": "/revenue",   "destination": "/revenue.html" },
    { "source": "/settings",  "destination": "/settings.html" },
    { "source": "/numbers",   "destination": "/numbers.html" },
    { "source": "/marketer",  "destination": "/marketer.html" },
    { "source": "/pricing",   "destination": "/pricing.html" }
  ],
  "redirects": [
    {
      "source": "/landing",
      "destination": "/",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' *; script-src 'self' 'unsafe-inline' 'unsafe-eval' *; style-src 'self' 'unsafe-inline' *; connect-src 'self' *; img-src 'self' data: *; media-src 'self' blob: *;"
        }
      ]
    }
  ]
}
